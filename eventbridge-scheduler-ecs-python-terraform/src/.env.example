# Sample environment variables for the cron job application
# Copy this file to .env and replace all <PLACEHOLDER> values with your actual configuration

# Database configuration
# Replace <DB_USERNAME>, <DB_PASSWORD>, <DB_HOST>, and <DB_NAME> with your database credentials
DATABASE_URL=postgresql://<DB_USERNAME>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>

# External API configuration
# Replace <YOUR_API_KEY> with your actual API key
API_KEY=<YOUR_API_KEY>
EXTERNAL_API_URL=https://jsonplaceholder.typicode.com/posts

# Processing configuration
BATCH_SIZE=100
PROCESSING_DELAY=0.1

# Retry configuration
MAX_RETRIES=3
RETRY_DELAY=1.0

# Logging configuration
LOG_LEVEL=INFO
