            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 16384
          },
          {
            "id": "global.anthropic.claude-opus-4-8",
            "name": "Claude Opus 4.8 (Bedrock)",
